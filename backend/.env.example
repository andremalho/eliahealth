# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=eliahealth

# JWT
JWT_SECRET=change-me-in-production

# Encryption
ENCRYPTION_KEY=change-me-32-char-encryption-key

# CORS
CORS_ORIGINS=http://localhost:3001,https://app.eliahealth.com

# App URL
APP_URL=https://app.eliahealth.com

# WhatsApp OTP
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE=otp_verification

# RNDS (Rede Nacional de Dados em Saude)
RNDS_ENABLED=false
RNDS_AUTH_URL=https://ehr.saude.gov.br/api/fhir/r4
RNDS_CLIENT_ID=
RNDS_CERTIFICATE_PATH=
RNDS_CERTIFICATE_PASSWORD=

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# CNES (Cadastro Nacional de Estabelecimentos de Saude)
CNES_ENABLED=false

# Anthropic (AI Copilot)
ANTHROPIC_API_KEY=
